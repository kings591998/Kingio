rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /ai_configs/{doc} { allow read, write: if request.auth != null; }
    match /payment_methods/{doc} { allow read: if true; allow write: if request.auth != null; }
    match /auto_schedules/{doc} { allow read, write: if request.auth != null; }
    match /system/{doc} { allow read, write: if request.auth != null; }
    match /{document=**} { allow read: if true; allow write: if request.auth != null; }
  }
}
